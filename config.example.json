{
  "database": {
    "host": "localhost",
    "port": "5432",
    "name": "aeron",
    "user": "aeron",
    "password": "",
    "schema": "aeron",
    "sslmode": "disable",
    "max_open_conns": 25,
    "max_idle_conns": 5,
    "conn_max_lifetime_minutes": 5
  },
  "image": {
    "target_width": 640,
    "target_height": 640,
    "quality": 85,
    "reject_smaller": false,
    "max_image_download_size_bytes": 52428800
  },
  "api": {
    "enabled": false,
    "keys": [],
    "request_timeout_seconds": 30,
    "read_timeout_seconds": 30,
    "write_timeout_seconds": 60,
    "idle_timeout_seconds": 120,
    "max_upload_body_bytes": 73400320
  },
  "maintenance": {
    "bloat_threshold": 10.0,
    "dead_tuple_threshold": 10000,
    "vacuum_staleness_days": 7,
    "min_rows_for_recommendation": 1000,
    "toast_size_warning_bytes": 524288000,
    "stale_stats_threshold_pct": 10,
    "seq_scan_ratio_threshold": 10.0,
    "connection_usage_threshold_pct": 80,
    "long_query_threshold_seconds": 10,
    "scheduler": {
      "enabled": false,
      "schedule": "0 4 * * 0"
    }
  },
  "backup": {
    "enabled": false,
    "path": "./backups",
    "retention_days": 30,
    "max_backups": 10,
    "default_compression": 9,
    "timeout_minutes": 30,
    "pg_dump_path": "",
    "pg_restore_path": "",
    "scheduler": {
      "enabled": false,
      "schedule": "0 3 * * *"
    },
    "s3": {
      "enabled": false,
      "bucket": "",
      "region": "",
      "endpoint": "",
      "access_key_id": "",
      "secret_access_key": "",
      "path_prefix": "",
      "force_path_style": false
    }
  },
  "file_monitor": {
    "enabled": false,
    "interval_seconds": 60,
    "checks": [
      {
        "name": "Nieuws bulletin",
        "path": "/data/news.mp3",
        "max_age_minutes": 30,
        "stat_timeout_seconds": 5,
        "active_window": "06:00-22:00"
      },
      {
        "name": "Weer",
        "path": "/data/weather.mp3",
        "max_age_minutes": 60,
        "stat_timeout_seconds": 5
      }
    ]
  },
  "media_file_check": {
    "enabled": false,
    "drive_mounts": {
      "O:": "/mnt/aeron-o",
      "Y:": "/mnt/aeron-y"
    },
    "search_dirs": [
      "/mnt/aeron-audio"
    ],
    "stat_timeout_seconds": 5,
    "max_range_days": 31,
    "case_insensitive": true,
    "include_voicetracks": false,
    "lookahead_days": 7,
    "scheduler": {
      "enabled": false,
      "schedule": "0 6 * * *"
    }
  },
  "notifications": {
    "email": {
      "tenant_id": "",
      "client_id": "",
      "client_secret": "",
      "from_address": "",
      "recipients": ""
    }
  },
  "log": {
    "level": "info",
    "format": "text"
  }
}
